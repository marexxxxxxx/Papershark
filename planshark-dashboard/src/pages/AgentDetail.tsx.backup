import { useEffect, useState, useRef } from 'react'
import { useParams, useNavigate } from 'react-router-dom'
import { useStore } from '@/stores/store'
import { agentApi } from '@/lib/api'

export default function AgentDetail() {
  const { id } = useParams()
  const navigate = useNavigate()
  const {
    agents,
    selectedAgent,
    selectedAgentConfig,
    selectedAgentSkills,
    chatMessages,
    selectAgent,
    updateAgentConfig,
    updateAgent,
    sendChatMessage,
    fetchAgentSkills,
    toggleAgentSkill,
    clearChat
  } = useStore()

  const [activeTab, setActiveTab] = useState<'config' | 'chat'>('config')
  const [chatInput, setChatInput] = useState('')
  const [loading, setLoading] = useState(false)
  const [logs, setLogs] = useState('')

  const [configForm, setConfigForm] = useState({
    agent_md: '',
    tool_md: '',
    heartbeat_md: '',
    model: ''
  })

  const chatEndRef = useRef<HTMLDivElement>(null)

  // If no ID is provided, try to select the first agent or show empty state
  useEffect(() => {
    if (!id && agents.length > 0) {
      navigate(`/agents/${agents[0].id}`, { replace: true })
    }
  }, [id, agents, navigate])

  useEffect(() => {
    if (id) {
      selectAgent(id)
      fetchAgentSkills(id)
    }
  }, [id])

  useEffect(() => {
    if (selectedAgentConfig && selectedAgent) {
      setConfigForm({
        agent_md: selectedAgentConfig.agent_md,
        tool_md: selectedAgentConfig.tool_md,
        heartbeat_md: selectedAgentConfig.heartbeat_md,
        model: selectedAgent.model || selectedAgent.gateway?.model || ''
      })
    }
  }, [selectedAgentConfig, selectedAgent])

  useEffect(() => {
    if (id && activeTab === 'config') {
      const fetchLogs = async () => {
        try {
          const res = await agentApi.getLogs(id)
          setLogs(res.logs)
        } catch (e) {
          console.error("Failed to fetch logs")
        }
      }
      fetchLogs()
      const interval = setInterval(fetchLogs, 5000)
      return () => clearInterval(interval)
    }
  }, [id, activeTab])

  useEffect(() => {
    chatEndRef.current?.scrollIntoView({ behavior: 'smooth' })
  }, [chatMessages, id])

  const handleSaveConfig = async () => {
    if (!id) return
    setLoading(true)
    try {
      await updateAgentConfig(id, {
        agent_md: configForm.agent_md,
        tool_md: configForm.tool_md,
        heartbeat_md: configForm.heartbeat_md
      })
      await updateAgent(id, { model: configForm.model })
      // Toast would be nice here
    } catch (e) {
      console.error(e)
    }
    setLoading(false)
  }

  const handleChat = async (e: React.FormEvent) => {
    e.preventDefault()
    if (!id || !chatInput.trim() || loading) return

    const msg = chatInput
    setChatInput('')
    setLoading(true)

    try {
      await sendChatMessage(id, msg)
    } catch (e) {
      console.error(e)
    }
    setLoading(false)
  }

  if (!id) {
    return (
      <div className="flex-1 flex items-center justify-center p-margin-page h-full bg-background">
        <div className="text-center">
          <span className="material-symbols-outlined text-[48px] text-outline mb-4">edit_note</span>
          <h2 className="font-headline-md text-headline-md text-on-surface mb-2">No Agent Selected</h2>
          <p className="font-body-sm text-body-sm text-on-surface-variant">Please select an agent from the Agents list to edit its configuration.</p>
        </div>
      </div>
    )
  }

  if (!selectedAgent) return (
    <div className="flex-1 flex items-center justify-center p-margin-page h-full">
      <span className="material-symbols-outlined animate-spin text-[32px] text-primary">sync</span>
    </div>
  )

  const messages = chatMessages[id] || []

  return (
    <div className="flex-1 flex overflow-hidden p-margin-page gap-gutter h-[calc(100vh-64px)] bg-background">
      {/* Left Column: Settings */}
      <section className="flex-1 overflow-y-auto bg-surface-container-low border border-outline-variant rounded-lg p-lg flex flex-col gap-xl">
        {/* Section Header */}
        <div className="flex items-center justify-between pb-sm border-b border-outline-variant shrink-0">
          <div>
            <h1 className="font-headline-md text-headline-md text-on-surface flex items-center gap-2">
              <span className="material-symbols-outlined text-[24px]">tune</span>
              Configuration: {selectedAgent.name}
            </h1>
            <div className="font-code-mono text-code-mono text-on-surface-variant text-[11px] mt-1 flex gap-4">
              <span>Provider: {selectedAgent.gateway?.name || 'None'}</span>
              <span>Status: <span className={selectedAgent.status === 'running' ? 'text-emerald-400' : 'text-outline'}>{selectedAgent.status}</span></span>
            </div>
          </div>
          <button
            onClick={handleSaveConfig}
            disabled={loading}
            className="bg-primary text-on-primary px-4 py-2 rounded font-label-caps text-label-caps hover:bg-primary-fixed transition-colors disabled:opacity-50"
          >
            {loading ? 'Saving...' : 'Save Changes'}
          </button>
        </div>

        {/* Model Configuration */}
        <div className="flex flex-col gap-sm shrink-0">
          <label className="font-label-caps text-label-caps text-on-surface-variant uppercase">Foundation Model</label>
          <div className="flex gap-md">
            <input
              type="text"
              value={configForm.model}
              onChange={e => setConfigForm({ ...configForm, model: e.target.value })}
              className="flex-1 bg-surface border border-outline-variant rounded p-2 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20 font-body-sm text-body-sm"
              placeholder={selectedAgent.gateway?.model || "Enter model name (e.g. gpt-4)"}
            />
            {/* Keeping the temperature slider as visual mockup as requested in HTML */}
            <div className="flex-1 flex flex-col justify-center gap-xs">
              <div className="flex justify-between items-center">
                <span className="font-label-caps text-label-caps text-outline">Temperature (Simulated)</span>
                <span className="font-code-mono text-code-mono text-primary">0.7</span>
              </div>
              <input type="range" min="0" max="1" step="0.1" defaultValue="0.7" className="w-full accent-primary h-1 bg-surface-variant rounded-lg appearance-none cursor-not-allowed opacity-50" disabled />
            </div>
          </div>
        </div>

        {/* Personality / System Prompt */}
        <div className="flex flex-col gap-sm flex-1 min-h-[300px]">
          <div className="flex justify-between items-center">
            <label className="font-label-caps text-label-caps text-on-surface-variant uppercase">Personality & Instructions</label>
            <span className="font-label-caps text-label-caps text-outline flex items-center gap-1 cursor-pointer hover:text-on-surface" onClick={() => setActiveTab(activeTab === 'config' ? 'chat' : 'config')}>
              <span className="material-symbols-outlined text-[14px]">{activeTab === 'config' ? 'visibility' : 'edit'}</span>
              Toggle View
            </span>
          </div>

          {activeTab === 'config' ? (
            <textarea
              value={configForm.agent_md}
              onChange={e => setConfigForm({ ...configForm, agent_md: e.target.value })}
              className="flex-1 bg-surface border border-outline-variant rounded p-md font-code-mono text-code-mono text-on-surface resize-none focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20 leading-relaxed"
              spellCheck="false"
              placeholder="You are an autonomous AI assistant..."
            />
          ) : (
            <div className="flex-1 bg-[#081425] border border-outline-variant rounded p-md font-code-mono text-[11px] text-green-400 overflow-y-auto whitespace-pre-wrap leading-relaxed shadow-inner">
              {logs || 'No logs available yet...'}
            </div>
          )}
        </div>

        {/* Skills / Tools */}
        <div className="flex flex-col gap-md shrink-0">
          <div className="flex justify-between items-center">
            <label className="font-label-caps text-label-caps text-on-surface-variant uppercase">Active Skills & Integrations</label>
            <button className="text-primary hover:text-primary-fixed text-sm flex items-center gap-1">
              <span className="material-symbols-outlined text-[16px]">add</span> Add Skill
            </button>
          </div>
          <div className="grid grid-cols-2 gap-md">
            {selectedAgentSkills.map(skill => (
              <div key={skill.skill_name} className={`bg-surface border border-outline-variant rounded p-sm flex items-center justify-between transition-opacity ${!skill.is_enabled ? 'opacity-60' : ''}`}>
                <div className="flex items-center gap-3">
                  <div className="w-8 h-8 bg-surface-variant rounded flex items-center justify-center text-outline">
                    <span className="material-symbols-outlined text-[18px]">integration_instructions</span>
                  </div>
                  <div className="flex flex-col">
                    <span className="font-body-sm text-body-sm text-on-surface font-medium capitalize">{skill.skill_name.replace(/_/g, ' ')}</span>
                    <span className="font-label-caps text-label-caps text-outline">Plugin</span>
                  </div>
                </div>
                <button
                  onClick={() => toggleAgentSkill(id, skill.skill_name, !skill.is_enabled)}
                  className={`w-8 h-4 rounded-full relative cursor-pointer flex items-center p-[2px] transition-colors ${skill.is_enabled ? 'bg-primary' : 'bg-surface-variant border border-outline-variant'}`}
                >
                  <div className={`w-3 h-3 rounded-full absolute transition-all ${skill.is_enabled ? 'bg-on-primary right-[2px]' : 'bg-outline left-[2px]'}`}></div>
                </button>
              </div>
            ))}
            {selectedAgentSkills.length === 0 && (
              <div className="col-span-2 text-center py-4 text-on-surface-variant font-body-sm text-body-sm border border-dashed border-outline-variant rounded">
                No skills discovered for this agent. Ensure the agent has started.
              </div>
            )}
          </div>
        </div>
      </section>

      {/* Right Column: Test Chat */}
      <section className="w-[450px] flex-shrink-0 bg-surface-container border border-outline-variant rounded-lg flex flex-col overflow-hidden">
        {/* Chat Header */}
        <div className="h-12 bg-surface-container-high border-b border-outline-variant flex items-center px-md justify-between shrink-0">
          <div className="flex items-center gap-2">
            <div className={`w-2 h-2 rounded-full ${selectedAgent.status === 'running' ? 'bg-emerald-500' : 'bg-outline'}`}></div>
            <span className="font-body-sm text-body-sm text-on-surface font-medium">Test Session: {selectedAgent.name}</span>
          </div>
          <button onClick={() => clearChat(id)} className="text-outline hover:text-on-surface" title="Clear Chat">
            <span className="material-symbols-outlined text-[18px]">delete_sweep</span>
          </button>
        </div>

        {/* Chat Messages Area */}
        <div className="flex-1 overflow-y-auto p-md flex flex-col gap-md">
          <div className="flex items-center justify-center">
            <span className="font-label-caps text-label-caps text-outline-variant bg-surface px-2 py-1 rounded">Session Started</span>
          </div>

          {messages.length === 0 && (
            <div className="flex-1 flex items-center justify-center text-on-surface-variant font-body-sm text-body-sm text-center">
              Send a message to interact with the agent.<br/>The agent must be running.
            </div>
          )}

          {messages.map((msg, i) => (
            <div key={i} className={`flex flex-col gap-1 ${msg.role === 'user' ? 'items-end' : 'items-start'}`}>
              <span className={`font-label-caps text-label-caps text-outline ${msg.role === 'user' ? 'mr-1' : 'ml-1'}`}>
                {msg.role === 'user' ? 'You' : 'Agent'}
              </span>
              <div className={`px-4 py-3 rounded-lg max-w-[85%] font-body-sm text-body-sm whitespace-pre-wrap ${
                msg.role === 'user'
                  ? 'bg-primary-container text-on-primary-container rounded-tr-sm'
                  : 'bg-surface-variant text-on-surface rounded-tl-sm border border-outline-variant'
              }`}>
                {msg.content}
              </div>
            </div>
          ))}
          <div ref={chatEndRef} />
        </div>

        {/* Chat Input Area */}
        <div className="p-md bg-surface-container-low border-t border-outline-variant shrink-0">
          <form onSubmit={handleChat} className="relative flex items-center bg-surface border border-outline-variant rounded focus-within:border-primary focus-within:ring-1 focus-within:ring-primary/20 transition-all">
            <button type="button" className="p-2 text-outline hover:text-on-surface">
              <span className="material-symbols-outlined text-[20px]">add_circle</span>
            </button>
            <textarea
              value={chatInput}
              onChange={e => setChatInput(e.target.value)}
              onKeyDown={e => {
                if (e.key === 'Enter' && !e.shiftKey) {
                  e.preventDefault();
                  handleChat(e as any);
                }
              }}
              className="flex-1 bg-transparent border-none focus:ring-0 text-on-surface font-body-sm text-body-sm py-2 px-1 resize-none h-10 leading-6"
              placeholder={selectedAgent.status === 'running' ? "Type a message to test..." : "Start the agent to send messages"}
              rows={1}
              disabled={loading || selectedAgent.status !== 'running'}
            />
            <button
              type="submit"
              disabled={loading || !chatInput.trim() || selectedAgent.status !== 'running'}
              className="p-2 text-primary hover:text-primary-fixed mr-1 flex items-center justify-center disabled:opacity-50"
            >
              <span className="material-symbols-outlined text-[20px] rounded bg-primary-container text-on-primary-container p-1">
                {loading ? 'sync' : 'send'}
              </span>
            </button>
          </form>
          <div className="flex justify-between items-center mt-2 px-1">
            <span className="font-label-caps text-label-caps text-outline">Shift + Enter for new line</span>
            {selectedAgent.status !== 'running' && (
              <span className="font-label-caps text-label-caps text-error">Agent is offline</span>
            )}
          </div>
        </div>
      </section>
    </div>
  )
}
